{
  "name": "AutoLlmsTxt",
  "author": [
    "[https://unistellar.risetvp.com/jason-reskin Jason Reskin]",
  ],
  "url": "https://www.mediawiki.org/wiki/Extension:AutoLlmsTxt",
  "description": "Generates llms.txt and llms-full.txt automatically for MediaWiki.",
  "version": "1.0.0",
  "license-name": "GPL-3.0+",
  "type": "other",
  "ExtensionMessagesFiles": {
    "AutoLlmsTxt": "AutoLlmsTxt.i18n.php"
  },
  "AutoloadClasses": {
    "AutoLlmsTxt": "AutoLlmsTxt_body.php"
  },
  "Hooks": {
    "AfterImportPage": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "PageDeleteComplete": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "ArticleUndelete": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "PageMoveComplete": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "ArticleMergeComplete": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "UploadComplete": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "RevisionUndeleted": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "RevisionRecordInserted": [
      "AutoLlmsTxt::writeLlmsFiles"
    ],
    "PageSaveComplete": [
      "AutoLlmsTxt::writeLlmsFiles"
    ]
  },
  "manifest_version": 1
}
